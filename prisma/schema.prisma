generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  bookingCode    String        @unique @map("booking_code")
  status         String        @default("waiting_payment") // waiting_payment, confirmed, completed, cancelled, expired
  totalAmount    Int           @map("total_amount")
  discountAmount Int           @default(0) @map("discount_amount")
  finalAmount    Int           @map("final_amount")
  note           String?
  expiresAt      DateTime?     @map("expires_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade, map: "bookings_userId_users_id_fk")
  items          BookingItem[]
  payments       Payment[]

  @@index([userId])
  @@index([status])
  @@map("bookings")
}

model BookingItem {
  id              String   @id @default(uuid())
  bookingId       String   @map("booking_id")
  fieldId         String   @map("field_id")
  venueId         String   @map("venue_id")
  date            DateTime @db.Date
  startTime       DateTime @map("start_time") @db.Time(6)
  endTime         DateTime @map("end_time") @db.Time(6)
  durationMinutes Int      @map("duration_minutes")
  pricePerHour    Int      @map("price_per_hour")
  subtotal        Int
  status          String   @default("active") // active, cancelled
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  field           Field    @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  venue           Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([fieldId, date])
  @@index([bookingId])
  @@map("booking_items")
}

model Field {
  id                  String        @id @default(uuid())
  name                String
  description         String?
  price               Int
  minDurationMinutes  Int           @default(60)
  durationStepMinutes Int           @default(30)
  status              String        @default("active") // active, inactive
  maintenanceReason   String?       @map("maintenance_reason")
  bookingCount        Int           @default(0) @map("booking_count")
  viewCount           Int           @default(0) @map("view_count")
  sportId             String
  venueId             String
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  bookingItems        BookingItem[]
  sport               Sport         @relation(fields: [sportId], references: [id], onDelete: Cascade, map: "fields_sportId_sports_id_fk")
  venue               Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade, map: "fields_venueId_venues_id_fk")
  fieldImages         FieldImages[]

  @@index([venueId, sportId, status])
  @@map("fields")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String    @default("system")
  title     String
  message   String
  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "notifications_userId_users_id_fk")

  @@index([userId, isRead])
  @@map("notifications")
}

model Payment {
  id                    String               @id @default(uuid())
  bookingId             String               @map("booking_id")
  amount                Int
  gateway               String?              @default("vnpay")
  method                String               @default("bank_transfer") // bank_transfer, momo, zalopay, vnpay
  status                String               @default("pending") // pending, success, failed, cancelled, refunded
  transactionCode       String?              @map("transaction_code")
  retryCount            Int                  @default(0) @map("retry_count")
  paidAt                DateTime?            @map("paid_at")
  venuePaymentAccountId String?              @map("venue_payment_account_id")
  gatewayResponse       Json?                @map("gateway_response")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  booking               Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade, map: "payments_bookingId_bookings_id_fk")
  venuePaymentAccount   VenuePaymentAccount? @relation(fields: [venuePaymentAccountId], references: [id], onDelete: SetNull)

  @@map("payments")
}

model Review {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  venueId   String   @map("venue_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  venue     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "reviews_userId_users_id_fk")

  @@unique([userId, venueId])
  @@index([venueId])
  @@map("reviews")
}

model Sport {
  id          String       @id @default(uuid())
  name        String       @unique
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  fields      Field[]
  venueSports VenueSport[]

  @@map("sports")
}

model VenueSport {
  id          String   @id @default(uuid())
  venueId     String   @map("venue_id")
  sportId     String   @map("sport_id")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  venue       Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  sport       Sport    @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@unique([venueId, sportId])
  @@map("venue_sports")
}

model UserPaymentMethod {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  type          String   @default("card") // card, bank_account, e_wallet
  provider      String
  providerToken String?
  maskedNumber  String?
  holderName    String?
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_payment_methods")
}

model PaymentMethod {
  id          String                @id @default(uuid())
  code        String                @unique
  name        String
  description String?
  isActive    Boolean               @default(true) @map("is_active")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  accounts    VenuePaymentAccount[]

  @@map("payment_methods")
}

model User {
  id             String              @id @default(uuid())
  name           String
  username       String
  email          String              @unique
  phone          String              @unique
  password       String
  role           String              @default("user") // user, admin, staff
  avatarUrl      String?             @map("avatar_url")
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  bookings       Booking[]
  notifications  Notification[]
  reviews        Review[]
  venueOwners    VenueOwner[]
  paymentMethods UserPaymentMethod[]
  venueFavorites UserVenueFavorite[]
  chatConversations ChatConversation[]
  chatMessages      ChatMessage[]

  @@map("users")
}

model VenuePaymentAccount {
  id              String        @id @default(uuid())
  venueId         String        @map("venue_id")
  paymentMethodId String        @map("payment_method_id")
  provider        String?
  accountNumber   String?
  accountName     String?
  bankCode        String?
  bankName        String?
  qrCodeUrl       String?
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  venue           Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict)
  payments        Payment[]

  @@unique([venueId, paymentMethodId])
  @@map("venue_payment_accounts")
}

model Venue {
  id              String                @id @default(uuid())
  name            String
  location        String
  longitude       Float                 @default(0)
  latitude        Float                 @default(0)
  openTime        String                @default("06:00")
  closeTime       String                @default("22:00")
  restStartTime   String?
  restEndTime     String?
  description     String?
  ratingAverage   Float                 @default(0) @map("rating_average")
  ratingCount     Int                   @default(0) @map("rating_count")
  bookingCount    Int                   @default(0) @map("booking_count")
  favoriteCount   Int                   @default(0) @map("favorite_count")
  viewCount       Int                   @default(0) @map("view_count")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  fields          Field[]
  bookingItems    BookingItem[]
  venueOwners     VenueOwner[]
  venueImages     VenueImages[]
  paymentAccounts VenuePaymentAccount[]
  venueAmenities  VenueAmenities[]
  venueSports     VenueSport[]
  venueFavorites  UserVenueFavorite[]
  reviews         Review[]
  chatConversations ChatConversation[]

  @@map("venues")
}

model VenueOwner {
  id        String   @id @default(uuid())
  venueId   String
  userId    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  venue     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([venueId, userId], map: "unique_venue_owner")
  @@map("venue_owners")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?  @map("actor_id")
  module     String?
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  fromValue  String?  @map("from_value")
  toValue    String?  @map("to_value")
  note       String?
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([module])
  @@map("audit_logs")
}

model VenueImages {
  id          String   @id @default(uuid())
  url         String
  venueId     String
  isThumbnail Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  venue       Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@map("venue_images")
}

model FieldImages {
  id          String   @id @default(uuid())
  url         String
  fieldId     String
  isThumbnail Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  field       Field    @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@map("field_images")
}

model Amenities {
  id          String           @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  venues      VenueAmenities[]

  @@map("amenities")
}

model VenueAmenities {
  id        String    @id @default(uuid())
  venueId   String
  amenityId String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  venue     Venue     @relation(fields: [venueId], references: [id])
  amenity   Amenities @relation(fields: [amenityId], references: [id])

  @@map("venue_amenities")
}

model UserVenueFavorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  venueId   String   @map("venue_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
  @@index([userId])
  @@map("user_venue_favorites")
}

model ChatConversation {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  venueId       String        @map("venue_id")
  lastMessageAt DateTime?     @map("last_message_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue         Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  messages      ChatMessage[]

  @@unique([userId, venueId])
  @@index([userId])
  @@index([venueId])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(uuid())
  conversationId String           @map("conversation_id")
  senderId       String           @map("sender_id")
  content        String
  isRead         Boolean          @default(false) @map("is_read")
  createdAt      DateTime         @default(now()) @map("created_at")
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User             @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}
